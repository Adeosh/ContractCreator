<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:ContractCreator.UI.ViewModels.Contracts.Documents"
			 xmlns:dto="using:ContractCreator.Shared.DTOs"
			 x:DataType="vm:InvoiceEditorViewModel"
			 x:Class="ContractCreator.UI.Views.Contracts.Documents.InvoiceEditorView"
			 Background="{DynamicResource RegionBrush}">

	<Grid RowDefinitions="Auto, *">

		<Border Grid.Row="0" Background="{DynamicResource CardBrush}" Padding="20,15" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrush}">
			<Grid ColumnDefinitions="Auto, *, Auto">
				<StackPanel Orientation="Horizontal" Spacing="15">
					<Button Command="{Binding CancelCommand}" Content="🠔" Classes="windowBtn" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryTextBrush}"/>
					<TextBlock Text="{Binding PageTitle}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
				</StackPanel>

				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
					<Button Content="Отмена" Command="{Binding CancelCommand}" Foreground="{DynamicResource PrimaryTextBrush}" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="20,8"/>
					<Button Content="Сохранить счет" Command="{Binding SaveCommand}" Background="{DynamicResource ActionBrush}" Foreground="White" FontWeight="Bold" Padding="20,8"/>
				</StackPanel>
			</Grid>
		</Border>

		<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
			<Grid>
				<StackPanel Spacing="20" Margin="20,25,20,30" MaxWidth="1100" HorizontalAlignment="Stretch" VerticalAlignment="Top">

					<Grid ColumnDefinitions="*, 20, *">

						<Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="5" Padding="20" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
							<StackPanel Spacing="15">
								<TextBlock Text="ОСНОВНЫЕ ДАННЫЕ" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" LetterSpacing="1"/>

								<Grid ColumnDefinitions="*, 20, *">
									<StackPanel Grid.Column="0" Spacing="5">
										<TextBlock Text="Счет №" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
										<TextBox Text="{Binding InvoiceNumber}" Watermark="Номер" Foreground="{DynamicResource PrimaryTextBrush}"/>
									</StackPanel>

									<StackPanel Grid.Column="2" Spacing="5">
										<TextBlock Text="Дата выставления" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
										<CalendarDatePicker SelectedDate="{Binding InvoiceDate, Converter={StaticResource DateConverter}}"
															HorizontalAlignment="Stretch"
															Foreground="{DynamicResource PrimaryTextBrush}"
															Watermark="Выберите дату"
															SelectedDateFormat="Custom"
															CustomDateFormatString="dd.MM.yyyy"/>
									</StackPanel>
								</Grid>

								<Separator Height="1" Background="{DynamicResource BorderBrush}" Margin="0,5"/>

								<StackPanel Spacing="5">
									<TextBlock Text="ЗАКАЗЧИК (ПОКУПАТЕЛЬ)" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" LetterSpacing="1"/>
									<TextBlock Text="{Binding PurchaserName}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}"/>
									<StackPanel Orientation="Horizontal" Spacing="15">
										<TextBlock Text="{Binding PurchaserINN, StringFormat='ИНН: {0}'}" Foreground="{DynamicResource SecondaryTextBrush}"/>
										<TextBlock Text="{Binding PurchaserKPP, StringFormat='КПП: {0}'}" Foreground="{DynamicResource SecondaryTextBrush}" IsVisible="{Binding !!PurchaserKPP.Length}"/>
									</StackPanel>
								</StackPanel>
							</StackPanel>
						</Border>

						<Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="5" Padding="20" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
							<StackPanel Spacing="15">
								<TextBlock Text="РЕКВИЗИТЫ ДЛЯ ОПЛАТЫ" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" LetterSpacing="1"/>

								<StackPanel Spacing="5">
									<TextBlock Text="Расчетный счет исполнителя" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
									<ComboBox ItemsSource="{Binding BankAccounts}"
											  SelectedItem="{Binding SelectedBankAccount}"
											  HorizontalAlignment="Stretch"
											  PlaceholderText="Выберите расчетный счет...">
										<ComboBox.ItemTemplate>
											<DataTemplate>
												<TextBlock Text="{Binding BankName}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
											</DataTemplate>
										</ComboBox.ItemTemplate>
									</ComboBox>
								</StackPanel>

								<Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="85, *" RowSpacing="10" Margin="0,5,0,0">
									<TextBlock Grid.Row="0" Grid.Column="0" Text="БИК:" Foreground="{DynamicResource SecondaryTextBrush}"/>
									<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedBankAccount.BIC}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="Medium"/>

									<TextBlock Grid.Row="1" Grid.Column="0" Text="Корр. счет:" Foreground="{DynamicResource SecondaryTextBrush}"/>
									<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedBankAccount.CorrespondentAccount}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="Medium"/>

									<TextBlock Grid.Row="2" Grid.Column="0" Text="Расч. счет:" Foreground="{DynamicResource SecondaryTextBrush}"/>
									<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedBankAccount.AccountNumber}" Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="Bold"/>
								</Grid>
							</StackPanel>
						</Border>
					</Grid>

					<Border Background="{DynamicResource CardBrush}" CornerRadius="5" Padding="20" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
						<StackPanel Spacing="15">
							<TextBlock Text="ПОЗИЦИИ СЧЕТА" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource SecondaryTextBrush}" LetterSpacing="1"/>

							<Grid ColumnDefinitions="*, 15, 120, 15, Auto">
								<ComboBox Grid.Column="0"
										  ItemsSource="{Binding AvailableSpecifications}"
										  SelectedItem="{Binding SelectedSpecificationToAdd}"
										  PlaceholderText="Выберите позицию из контракта..."
										  HorizontalAlignment="Stretch">
									<ComboBox.ItemTemplate>
										<DataTemplate>
											<TextBlock Text="{Binding NomenclatureName}" Foreground="{DynamicResource PrimaryTextBrush}"/>
										</DataTemplate>
									</ComboBox.ItemTemplate>
								</ComboBox>

								<NumericUpDown Grid.Column="2" Value="{Binding QuantityToAdd}" Minimum="1" FormatString="0" Foreground="{DynamicResource PrimaryTextBrush}"/>

								<Button Grid.Column="4" Command="{Binding AddItemCommand}" Background="{DynamicResource ActionBrush}" Foreground="White" Padding="20,5" CornerRadius="5">
									<StackPanel Orientation="Horizontal" Spacing="5">
										<TextBlock Text="+" FontWeight="Bold"/>
										<TextBlock Text="Добавить"/>
									</StackPanel>
								</Button>
							</Grid>

							<DataGrid ItemsSource="{Binding InvoiceItems}"
									  AutoGenerateColumns="False"
									  IsReadOnly="True"
									  MinHeight="180"
									  BorderThickness="1"
									  BorderBrush="{DynamicResource BorderBrush}"
									  GridLinesVisibility="Horizontal"
									  Background="Transparent">
								<DataGrid.Columns>
									<DataGridTextColumn Header="Наименование" Binding="{Binding NomenclatureName}" Width="*"/>
									<DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
									<DataGridTextColumn Header="Ед. изм." Binding="{Binding UnitOfMeasure}" Width="80"/>
									<DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat='{}{0:N2}'}" Width="130"/>
									<DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat='{}{0:N2}'}" Width="140"/>
									<DataGridTemplateColumn Header="" Width="50">
										<DataGridTemplateColumn.CellTemplate>
											<DataTemplate>
												<Button Command="{Binding $parent[UserControl].((vm:InvoiceEditorViewModel)DataContext).RemoveItemCommand}"
														CommandParameter="{Binding}"
														Content="✕" Foreground="{DynamicResource ErrorBrush}" Background="Transparent" Padding="5"
														HorizontalAlignment="Center" VerticalAlignment="Center"/>
											</DataTemplate>
										</DataGridTemplateColumn.CellTemplate>
									</DataGridTemplateColumn>
								</DataGrid.Columns>
							</DataGrid>

							<Separator Height="1" Background="{DynamicResource BorderBrush}" Margin="0,10"/>

							<Grid ColumnDefinitions="Auto, *">
								<StackPanel Grid.Column="0" VerticalAlignment="Bottom">
									<TextBlock Text="Ставка НДС (%)" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,5"/>
									<NumericUpDown Value="{Binding VATRate}" Minimum="0" Maximum="100" Width="120" HorizontalAlignment="Left" Foreground="{DynamicResource PrimaryTextBrush}"/>
								</StackPanel>

								<Grid Grid.Column="1" RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="Auto, 160" RowSpacing="6" HorizontalAlignment="Right">
									<TextBlock Grid.Row="0" Grid.Column="0" Text="Сумма без НДС:" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
									<TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalAmount, StringFormat='{}{0:N2}'}" TextAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>

									<TextBlock Grid.Row="1" Grid.Column="0" Text="Сумма НДС:" HorizontalAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
									<TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VATAmount, StringFormat='{}{0:N2}'}" TextAlignment="Right" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>

									<TextBlock Grid.Row="2" Grid.Column="0" Text="ИТОГО К ОПЛАТЕ:" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="0,10,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
									<TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AggregateAmount, StringFormat='{}{0:N2} ₽'}" TextAlignment="Right" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,10,0,0"/>
								</Grid>
							</Grid>
						</StackPanel>
					</Border>
				</StackPanel>
			</Grid>
		</ScrollViewer>
	</Grid>
</UserControl>