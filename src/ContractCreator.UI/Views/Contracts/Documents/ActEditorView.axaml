<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ContractCreator.UI.ViewModels.Contracts.Documents"
             xmlns:conv="using:ContractCreator.UI.Converters"
             x:DataType="vm:ActEditorViewModel"
             x:Name="Root"
             x:Class="ContractCreator.UI.Views.Contracts.Documents.ActEditorView">

    <Grid RowDefinitions="Auto, *, Auto" Margin="10">

        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Padding="15" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel Orientation="Horizontal" Spacing="15">
                <Button Command="{Binding CancelCommand}" Content="🠔" Classes="windowBtn"/>
                <TextBlock Text="{Binding PageTitle}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">

                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E0E0">
                    <Grid ColumnDefinitions="*, *">
                        
                        <StackPanel Grid.Column="0" Spacing="15" Margin="0,0,20,0">
                            <TextBlock Text="Реквизиты документа" FontSize="16" FontWeight="SemiBold"/>

                            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto" RowSpacing="10">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Акт №:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ActNumber}" Watermark="Введите номер"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="от:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                <DatePicker Grid.Row="1" Grid.Column="1"
													SelectedDate="{Binding ActDate, Converter={StaticResource DateConverter}}"
													HorizontalAlignment="Stretch"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Основание:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" 
                                          ItemsSource="{Binding AvailableInvoices}"
                                          SelectedItem="{Binding SelectedInvoice}"
                                          PlaceholderText="Выберите счет"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Счет № {0} от {1:dd.MM.yyyy}">
                                                        <Binding Path="InvoiceNumber"/>
                                                        <Binding Path="InvoiceDate"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <TextBlock Text="Заказчик" FontSize="16" FontWeight="SemiBold"/>
                            <Border Background="#F5F5F5" Padding="10" CornerRadius="5">
                                <TextBlock Text="{Binding PurchaserName}" FontWeight="Bold" TextWrapping="Wrap"/>
                            </Border>
                            <TextBlock Text="* Акт составляется на основании выставленного счета." 
                                       Foreground="Gray" FontStyle="Italic" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Состав выполненных работ (оказанных услуг)" FontSize="16" FontWeight="SemiBold"/>

                        <Grid ColumnDefinitions="*, 100, Auto" Margin="0,10,0,10">
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding AvailableInvoiceItems}"
                                      SelectedItem="{Binding SelectedItemToAdd}"
                                      PlaceholderText="Выберите позицию из выбранного счета"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding NomenclatureName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding RemainingQuantity, StringFormat='(Остаток по счету: {0})'}" Foreground="Gray"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <NumericUpDown Grid.Column="1" Width="120" Value="{Binding QuantityToAdd}" Minimum="1" Margin="10,0,10,0"/>

                            <Button Grid.Column="2" Command="{Binding AddItemCommand}" Content="+ Добавить" Classes="accent"/>
                        </Grid>

                        <DataGrid ItemsSource="{Binding ActItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MinHeight="150"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование работ/услуг" Binding="{Binding NomenclatureName}" Width="*"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                                <DataGridTextColumn Header="Ед. изм." Binding="{Binding UnitOfMeasure}" Width="80"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat='{}{0:N2}'}" Width="120"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat='{}{0:N2}'}" Width="120" FontWeight="Bold"/>
                                <DataGridTemplateColumn Header=" " Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{ReflectionBinding #Root.DataContext.RemoveItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    Content="❌" Foreground="Red" Background="Transparent" Padding="5"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#E0E0E0">
                    <Grid ColumnDefinitions="*, Auto">

                        <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                            <TextBlock Text="Ставка НДС (%)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <NumericUpDown Value="{Binding VATRate}" Minimum="0" Maximum="100" Width="120" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto, 150" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Сумма без НДС:" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalAmount, StringFormat='{}{0:N2}'}" TextAlignment="Right" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Сумма НДС:" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding VATAmount, StringFormat='{}{0:N2}'}" TextAlignment="Right" FontWeight="SemiBold"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="ИТОГО ПО АКТУ:" HorizontalAlignment="Right" FontWeight="Bold" FontSize="18"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AggregateAmount, StringFormat='{}{0:N2}'}" TextAlignment="Right" FontWeight="Bold" FontSize="18" Foreground="#2E7D32"/>
                        </Grid>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" Margin="0,10,0,0" Padding="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Отмена" Command="{Binding CancelCommand}" Width="100" HorizontalContentAlignment="Center"/>
                <Button Content="Сохранить Акт" Command="{Binding SaveCommand}" Classes="accent" Width="140" HorizontalContentAlignment="Center" Background="#1976D2" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>