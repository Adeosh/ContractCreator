<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:ContractCreator.UI.ViewModels.Dashboard"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
			 x:Class="ContractCreator.UI.Views.Dashboard.DashboardView"
			 x:DataType="vm:DashboardViewModel"
			 Background="{DynamicResource RegionBrush}">

	<UserControl.Styles>
		<Style Selector="Border.Card">
			<Setter Property="Background" Value="{DynamicResource CardBrush}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="25"/>
			<Setter Property="BoxShadow" Value="0 4 15 0 #0A000000"/> <Setter Property="Margin" Value="10"/>
		</Style>

		<Style Selector="TextBlock.CardTitle">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
			<Setter Property="LetterSpacing" Value="1"/> <Setter Property="Margin" Value="0,0,0,15"/>
		</Style>
	</UserControl.Styles>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Spacing="15" Margin="20,30,20,40" MaxWidth="2500" HorizontalAlignment="Center">

			<Grid ColumnDefinitions="*, Auto" Margin="10,0,10,20">
				<StackPanel Spacing="5">
					<TextBlock Text="{Binding FirmName}"
							   FontSize="28"
							   FontWeight="Bold"
							   Foreground="{DynamicResource PrimaryTextBrush}"/>
					<TextBlock Text="{Binding FirmInnKpp}"
							   FontSize="14"
							   Foreground="{DynamicResource SecondaryTextBrush}"/>
				</StackPanel>

				<Button Grid.Column="1"
						Command="{Binding ChangeFirmCommand}"
						Content="Сменить организацию"
						Classes="accent"
						VerticalAlignment="Center"/>
			</Grid>

			<UniformGrid Columns="4">
				<Border Classes="Card">
					<StackPanel>
						<TextBlock Text="ДОГОВОРОВ В РАБОТЕ" Classes="CardTitle"/>
						<TextBlock Text="{Binding TotalActiveContracts}"
								   FontSize="32" FontWeight="Bold"
								   Foreground="{DynamicResource PrimaryTextBrush}"/>
					</StackPanel>
				</Border>

				<Border Classes="Card">
					<StackPanel>
						<TextBlock Text="ОБЩАЯ СУММА (АКТИВНЫЕ)" Classes="CardTitle"/>
						<TextBlock Text="{Binding TotalActiveContractsValue, StringFormat={}{0:N2} ₽}"
								   FontSize="24" FontWeight="Bold"
								   Foreground="{DynamicResource ActionBrush}"/>
					</StackPanel>
				</Border>

				<Border Classes="Card">
					<StackPanel>
						<TextBlock Text="ИСТЕКАЮТ (30 ДНЕЙ)" Classes="CardTitle"/>
						<TextBlock Text="{Binding ExpiringContractsCount}"
								   FontSize="32" FontWeight="Bold"
								   Foreground="{DynamicResource ErrorBrush}"/>
					</StackPanel>
				</Border>

				<Border Classes="Card">
					<StackPanel>
						<TextBlock Text="СЧЕТА ЗА ТЕК. ГОД" Classes="CardTitle"/>
						<TextBlock Text="{Binding TotalPendingInvoicesValue, StringFormat={}{0:N2} ₽}"
								   FontSize="24" FontWeight="Bold"
								   Foreground="{DynamicResource PrimaryTextBrush}"/>
					</StackPanel>
				</Border>
			</UniformGrid>

			<Grid ColumnDefinitions="*, 1.5*" Height="400">

				<Border Grid.Column="0" Classes="Card">
					<DockPanel>
						<TextBlock DockPanel.Dock="Top" Text="СТАТУСЫ ДОКУМЕНТОВ" Classes="CardTitle"/>

						<Panel>
							<TextBlock Text="Нет данных для отображения"
									   VerticalAlignment="Center"
									   HorizontalAlignment="Center"
									   Foreground="{DynamicResource SecondaryTextBrush}"
									   IsVisible="{Binding !ContractsByStageChart.Count}"/>

							<ItemsControl ItemsSource="{Binding ContractsByStageChart}"
										  IsVisible="{Binding !!ContractsByStageChart.Count}"
										  VerticalAlignment="Top">
								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Grid ColumnDefinitions="*, Auto" Margin="0,8">
											<TextBlock Text="{Binding Label}" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
											<TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="Bold" FontSize="16" Margin="20,0,0,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
										</Grid>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</Panel>
					</DockPanel>
				</Border>

				<Border Grid.Column="1" Classes="Card">
					<DockPanel>
						<Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
							<TextBlock Text="ПОСЛЕДНИЕ ДОГОВОРЫ" Classes="CardTitle" VerticalAlignment="Center" Margin="0"/>
							<Button Grid.Column="1"
									Command="{Binding GoToContractsCommand}"
									Content="Показать все"
									Background="Transparent"
									Foreground="{DynamicResource ActionBrush}"
									BorderThickness="0"
									FontWeight="SemiBold"
									Cursor="Hand"/>
						</Grid>

						<DataGrid ItemsSource="{Binding RecentContracts}"
								  IsReadOnly="True"
								  CanUserResizeColumns="True"
								  GridLinesVisibility="Horizontal"
								  BorderThickness="1"
								  BorderBrush="{DynamicResource BorderBrush}"
								  Background="Transparent">
							<DataGrid.Columns>
								<DataGridTextColumn Header="Номер" Binding="{Binding ContractNumber}" Width="Auto"/>
								<DataGridTextColumn Header="Предмет" Binding="{Binding ContractSubject}" Width="*"/>
								<DataGridTextColumn Header="Сумма" Binding="{Binding ContractPrice, StringFormat={}{0:N2}}" Width="140"/>
							</DataGrid.Columns>
						</DataGrid>
					</DockPanel>
				</Border>
			</Grid>
		</StackPanel>
	</ScrollViewer>
</UserControl>